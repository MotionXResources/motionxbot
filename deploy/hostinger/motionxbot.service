[Unit]
Description=MotionXBot Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/motionxbot
EnvironmentFile=/opt/motionxbot/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/motionxbot/.venv/bin/python -m motionxbot
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
